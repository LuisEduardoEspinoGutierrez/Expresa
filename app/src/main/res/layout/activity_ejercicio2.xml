<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="12dp">

    <!-- BOTÓN REGRESAR -->
    <ImageView
        android:id="@+id/ivRegresar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/back"
        android:padding="8dp"
        android:contentDescription="Regresar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvInstrucciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Arrastra las imágenes que empiezan con 'R'"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/ivRegresar"
        app:layout_constraintBottom_toBottomOf="@id/ivRegresar"
        app:layout_constraintStart_toEndOf="@id/ivRegresar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ZONA DE DROP (LETRA R) -->
    <ImageView
        android:id="@+id/zonaR"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/r"
        android:padding="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvInstrucciones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- GRID DE IMÁGENES (4 Columnas) -->
    <GridLayout
        android:id="@+id/gridImagenes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:useDefaultMargins="true"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/zonaR"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
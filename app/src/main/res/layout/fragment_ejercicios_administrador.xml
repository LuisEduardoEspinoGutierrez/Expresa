<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdministradorEjerciciosFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejercicios de Administrador"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp" />

        <Button
            android:id="@+id/btnEjercicio2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 2"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp" />

        <Button
            android:id="@+id/btnEjercicio3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 3"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 4"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio7_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 7.1"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio7_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 7.2"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio7_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 7.3"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio7_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 7.4"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnEjercicio10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ir a Ejercicio 10 (Sopa de Letras)"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="15dp"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</ScrollView>
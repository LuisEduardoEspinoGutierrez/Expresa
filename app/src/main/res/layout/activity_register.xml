<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".RegisterActivity">

    <!-- Barra superior (fuera del ScrollView para que siempre se vea) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#38A9F5"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivRegresar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/regresar"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <!-- ScrollView con UN SOLO HIJO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:fillViewport="true">  <!-- Importante para el contenido -->

        <!-- ÚNICO HIJO DEL SCROLLVIEW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/ivLogin"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/register"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar usuario"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completa todos los datos para crear tu cuenta"
                android:textSize="18sp"
                android:textColor="#757575"
                android:layout_marginBottom="32dp" />

            <!-- PRIMER CAMPO: Usuario -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:startIconDrawable="@drawable/user"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#38A9F5"
                app:startIconContentDescription="Icono usuario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ingresa tu nombre completo"
                    android:textSize="18sp"
                    android:paddingStart="48dp"
                    android:paddingLeft="48dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Correo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Correo"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:startIconDrawable="@drawable/email"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#38A9F5"
                app:startIconContentDescription="Icono usuario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ingresa tu correo"
                    android:textSize="18sp"
                    android:inputType="textEmailAddress"
                    android:paddingStart="48dp"
                    android:paddingLeft="48dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Tipo de usuario (Dropdown) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo de usuario"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:startIconDrawable="@drawable/user_type"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#38A9F5"
                app:endIconMode="dropdown_menu"
                app:startIconContentDescription="Icono usuario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:id="@+id/actTipoUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Selecciona tu tipo de usuario"
                    android:textSize="18sp"
                    android:paddingStart="48dp"
                    android:paddingLeft="48dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:completionThreshold="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:startIconDrawable="@drawable/lock"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#38A9F5"
                app:passwordToggleEnabled="true"
                app:endIconMode="password_toggle"
                app:startIconContentDescription="Icono contraseña"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Crea una contraseña segura"
                    android:textSize="18sp"
                    android:inputType="textPassword"
                    android:paddingVertical="16dp"
                    android:paddingStart="48dp"
                    android:paddingLeft="48dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Confirmar Contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirmar contraseña"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:startIconDrawable="@drawable/lock"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#38A9F5"
                app:passwordToggleEnabled="true"
                app:endIconMode="password_toggle"
                app:startIconContentDescription="Icono contraseña"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmarContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirma tu contraseña"
                    android:textSize="18sp"
                    android:inputType="textPassword"
                    android:paddingVertical="16dp"
                    android:paddingStart="48dp"
                    android:paddingLeft="48dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botones horizontales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnRegistrar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Registrar"
                    android:textAllCaps="false"
                    android:layout_margin="8dp"
                    android:backgroundTint="#38A9F5"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:padding="12dp"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnCancelar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancelar"
                    android:textAllCaps="false"
                    android:layout_margin="8dp"
                    android:backgroundTint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:padding="12dp"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout> <!-- Cierra el LinearLayout interno (ÚNICO HIJO DEL SCROLLVIEW) -->

    </ScrollView> <!-- Cierra el ScrollView -->

</LinearLayout> <!-- Cierra el LinearLayout principal -->
